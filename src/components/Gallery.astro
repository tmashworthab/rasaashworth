---
import type { Work } from '../data/works';

interface Props {
  works: Work[];
}
const { works } = Astro.props;
---

<ul class="gallery" role="list">
  {
    works.map((work, i) => (
      <li class:list={['gallery__item reveal', `is-${work.orientation}`]}>
        <button
          class="gallery__trigger"
          data-index={i}
          data-src={work.image}
          data-title={work.title}
          data-series={work.series}
          data-desc={work.description}
        >
          <span class="gallery__frame">
            <img src={work.image} alt={`${work.title}, a woven tapestry by Rasa Ashworth`} loading="lazy" />
          </span>
          <span class="gallery__meta">
            <span class="gallery__title">{work.title}</span>
            <span class="gallery__series">{work.series}</span>
          </span>
        </button>
      </li>
    ))
  }
</ul>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Artwork viewer">
  <button class="lightbox__close" aria-label="Close">&times;</button>
  <button class="lightbox__nav lightbox__nav--prev" aria-label="Previous">&#8249;</button>
  <button class="lightbox__nav lightbox__nav--next" aria-label="Next">&#8250;</button>
  <figure class="lightbox__figure">
    <img class="lightbox__img" src="" alt="" />
    <figcaption class="lightbox__caption">
      <span class="lightbox__series"></span>
      <span class="lightbox__title"></span>
      <span class="lightbox__desc"></span>
    </figcaption>
  </figure>
</div>

<style>
  .gallery {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: clamp(1.75rem, 4vw, 4rem);
  }
  @media (min-width: 56rem) {
    .gallery {
      columns: 3;
    }
  }
  @media (max-width: 30rem) {
    .gallery {
      columns: 1;
    }
  }
  .gallery__item {
    break-inside: avoid;
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }
  .gallery__trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    text-align: left;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }
  /* Each piece is already framed; the wall is trimmed away so it sits
     directly on the linen. A soft shadow gives the hung-on-the-wall feel. */
  .gallery__frame {
    display: block;
    filter: drop-shadow(0 14px 30px rgba(46, 42, 36, 0.18));
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1),
      filter 0.5s ease;
  }
  .gallery__frame img {
    width: 100%;
    height: auto;
    display: block;
  }
  .gallery__trigger:hover .gallery__frame {
    transform: translateY(-6px);
    filter: drop-shadow(0 26px 50px rgba(46, 42, 36, 0.26));
  }
  .gallery__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.25rem 0.2rem 0;
    text-align: center;
  }
  .gallery__title {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--ink);
  }
  .gallery__series {
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* ---- Lightbox -------------------------------------------------------- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
    background: rgba(26, 23, 19, 0.93);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .lightbox.is-open {
    display: flex;
    opacity: 1;
  }
  .lightbox__figure {
    margin: 0;
    max-width: min(92vw, 60rem);
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .lightbox__img {
    max-width: 100%;
    max-height: 70vh;
    width: auto;
    height: auto;
    object-fit: contain;
    background: var(--paper);
    padding: clamp(0.75rem, 2vw, 1.5rem);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }
  .lightbox__caption {
    text-align: center;
    color: var(--linen);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-width: 38rem;
  }
  .lightbox__series {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ochre);
  }
  .lightbox__title {
    font-family: var(--serif);
    font-size: 1.7rem;
  }
  .lightbox__desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--linen) 80%, transparent);
  }
  .lightbox__close,
  .lightbox__nav {
    position: absolute;
    background: transparent;
    border: 0;
    color: var(--linen);
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .lightbox__close {
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    font-size: 2.5rem;
  }
  .lightbox__nav {
    top: 50%;
    transform: translateY(-50%);
    font-size: 3.5rem;
    padding: 0 1rem;
  }
  .lightbox__nav--prev { left: clamp(0.25rem, 2vw, 1.5rem); }
  .lightbox__nav--next { right: clamp(0.25rem, 2vw, 1.5rem); }
  .lightbox__close:hover,
  .lightbox__nav:hover { color: var(--ochre); }
  .lightbox__nav--prev:hover { transform: translateY(-50%) translateX(-3px); }
  .lightbox__nav--next:hover { transform: translateY(-50%) translateX(3px); }

  @media (max-width: 40rem) {
    .lightbox__nav { font-size: 2.25rem; }
    .lightbox__desc { display: none; }
  }
</style>

<script>
  type Item = { src: string; title: string; series: string; desc: string };

  const triggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.gallery__trigger')
  );
  const items: Item[] = triggers.map((t) => ({
    src: t.dataset.src ?? '',
    title: t.dataset.title ?? '',
    series: t.dataset.series ?? '',
    desc: t.dataset.desc ?? '',
  }));

  const box = document.getElementById('lightbox');
  if (box && triggers.length) {
    const img = box.querySelector<HTMLImageElement>('.lightbox__img')!;
    const elTitle = box.querySelector('.lightbox__title')!;
    const elSeries = box.querySelector('.lightbox__series')!;
    const elDesc = box.querySelector('.lightbox__desc')!;
    let current = 0;

    const render = (i: number) => {
      current = (i + items.length) % items.length;
      const it = items[current];
      img.src = it.src;
      img.alt = `${it.title}, a woven tapestry by Rasa Ashworth`;
      elTitle.textContent = it.title;
      elSeries.textContent = it.series;
      elDesc.textContent = it.desc;
    };

    const open = (i: number) => {
      render(i);
      box.classList.add('is-open');
      box.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      box.classList.remove('is-open');
      box.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    triggers.forEach((t, i) => t.addEventListener('click', () => open(i)));
    box.querySelector('.lightbox__close')?.addEventListener('click', close);
    box.querySelector('.lightbox__nav--prev')?.addEventListener('click', () => render(current - 1));
    box.querySelector('.lightbox__nav--next')?.addEventListener('click', () => render(current + 1));
    box.addEventListener('click', (e) => {
      if (e.target === box) close();
    });
    document.addEventListener('keydown', (e) => {
      if (!box.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') render(current - 1);
      if (e.key === 'ArrowRight') render(current + 1);
    });
  }
</script>
