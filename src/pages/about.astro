---
import Base from '../layouts/Base.astro';
import { getSettings } from '../lib/content';

const settings = await getSettings();
---

<Base
  title="About · Rasa Ashworth"
  description="About Rasa Ashworth, a Lithuanian tapestry artist trained at the Vilnius Academy of Arts and working in Bristol, UK."
>
  <section class="section about">
    <div class="wrap about__grid">
      <figure class="about__portrait reveal">
        <img
          src="/images/rasa-portrait.jpg"
          alt="Rasa Ashworth standing beside one of her large woven tapestries"
        />
        <figcaption>
          Me in 1989, beside one of my larger tapestries, woven on commission
          for the Kaunas electricity board in Lithuania.
        </figcaption>
      </figure>

      <div class="about__text reveal">
        <span class="eyebrow">About the Artist</span>
        <h1>Rasa Ashworth</h1>

        <p class="lead">{settings.aboutLead}</p>

        {settings.aboutBody.map((para) => <p>{para}</p>)}

        <hr class="divider" />

        <dl class="about__facts">
          <div>
            <dt>Training</dt>
            <dd>Vilnius Academy of Arts</dd>
          </div>
          <div>
            <dt>Based in</dt>
            <dd>Bristol, United Kingdom</dd>
          </div>
          <div>
            <dt>Medium</dt>
            <dd>Hand-woven tapestry, wool &amp; linen</dd>
          </div>
          <div>
            <dt>Themes</dt>
            <dd>Landscape · Still life · Figures · Bristol seascapes</dd>
          </div>
        </dl>

        <a href="/contact" class="btn btn--accent">Get in touch</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .about__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 50rem) {
    .about__grid {
      grid-template-columns: 1.15fr 0.85fr;
    }
    .about__portrait {
      position: sticky;
      top: 6.5rem;
    }
  }
  .about__portrait {
    margin: 0;
  }
  .about__portrait img {
    width: 100%;
    display: block;
  }
  .about__portrait figcaption {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink-soft);
    padding-top: 0.85rem;
  }
  .about__facts {
    margin: 0 0 2.5rem;
    display: grid;
    gap: 1.25rem;
  }
  @media (min-width: 30rem) {
    .about__facts {
      grid-template-columns: 1fr 1fr;
    }
  }
  .about__facts dt {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 0.3rem;
  }
  .about__facts dd {
    margin: 0;
    font-family: var(--serif);
    font-size: 1.2rem;
    color: var(--ink);
    line-height: 1.3;
  }
</style>
