---
import Base from '../layouts/Base.astro';
import { getSettings } from '../lib/content';

const settings = await getSettings();
const email = settings.contactEmail;
const btgUrl = settings.btgUrl;
const studio = settings.studioLocation;

// Contact form delivery via Web3Forms (https://web3forms.com) - free, no
// account. Get an access key in ~30s: enter rasa.ashworth@live.co.uk at
// web3forms.com, confirm the email it sends, then paste the key here.
// Submissions are then emailed straight to that address. Until a key is set,
// the form is hidden and the email link above is used instead.
const web3formsKey = '7033556a-1fcf-435d-96f8-ea43c4464f13';
---

<Base
  title="Contact · Rasa Ashworth"
  description="Contact Rasa Ashworth about available tapestries, commissions and exhibitions."
>
  <section class="section contact">
    <div class="wrap contact__grid">
      <div class="contact__intro reveal">
        <span class="eyebrow">Contact</span>
        <h1>Get in touch</h1>
        <p class="lead">
          For available work, commissions, exhibitions or any enquiry, I would
          love to hear from you.
        </p>

        <ul class="contact__list">
          <li>
            <span class="contact__label">Email</span>
            <a href={`mailto:${email}`} class="contact__big">{email}</a>
          </li>
          <li>
            <span class="contact__label">Studio</span>
            <span>{studio}</span>
          </li>
          <li>
            <span class="contact__label">Also find me on</span>
            <a href={btgUrl} target="_blank" rel="noopener">British Tapestry Group</a>
          </li>
        </ul>
      </div>

      {
        web3formsKey && (
          <form class="contact__form reveal" id="contact-form">
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="New enquiry from rasaashworth.com" />
            <input type="hidden" name="from_name" value="rasaashworth.com" />
            {/* Honeypot - bots fill this; humans never see it */}
            <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

            <label>
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label>
              <span>Message</span>
              <textarea name="message" rows="5" required></textarea>
            </label>
            <button type="submit" class="btn btn--accent">Send message</button>
            <p class="contact__status" role="status" aria-live="polite"></p>
          </form>
        )
      }
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (form) {
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const status = form.querySelector('.contact__status') as HTMLElement;
      const btnLabel = btn.textContent;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        status.classList.remove('is-error', 'is-success');
        btn.disabled = true;
        btn.textContent = 'Sending…';

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { Accept: 'application/json' },
            body: new FormData(form),
          });
          const data = await res.json();
          if (data.success) {
            form.reset();
            status.textContent =
              'Thank you, your message has been sent. Rasa will be in touch soon.';
            status.classList.add('is-success');
          } else {
            throw new Error(data.message || 'Submission failed');
          }
        } catch (err) {
          status.textContent =
            'Sorry, something went wrong. Please email rasa.ashworth@live.co.uk directly.';
          status.classList.add('is-error');
        } finally {
          btn.disabled = false;
          btn.textContent = btnLabel;
        }
      });
    }
  </script>
</Base>

<style>
  .contact__grid {
    display: grid;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }
  @media (min-width: 52rem) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .contact__list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.75rem;
  }
  .contact__label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 0.4rem;
  }
  .contact__big {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
  .contact__big:hover {
    color: var(--terracotta-deep);
    border-color: var(--terracotta);
  }

  .contact__form {
    display: grid;
    gap: 1.25rem;
    background: var(--paper);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--line);
  }
  .contact__form label {
    display: grid;
    gap: 0.4rem;
  }
  .contact__form span {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .contact__form input,
  .contact__form textarea {
    font: inherit;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--linen);
    color: var(--ink);
  }
  .contact__form input:focus,
  .contact__form textarea:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 1px;
    border-color: transparent;
  }
  .contact__form textarea {
    resize: vertical;
    min-height: 7rem;
  }
  /* Honeypot - visually hidden, off-screen, not announced */
  .hp {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .contact__status {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    min-height: 1.2em;
  }
  .contact__status.is-success {
    color: var(--moss);
  }
  .contact__status.is-error {
    color: var(--terracotta-deep);
  }
</style>
